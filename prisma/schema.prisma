generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum AuthType {
  CREDENTIALS
  GOOGLE
  FACEBOOK
}

enum Season {
  summer
  winter
}

enum UserMembershipStatus {
  PENDING
  REJECTED
  SUCCESSFUL
}

enum PaymentMethod {
  CASH
}

model Membership {
  id          String  @id
  name        String
  price       String
  period      String
  features    Json
  highlighted Boolean @default(false)
  badge       String?

  users         User[]
  userMemberships UserMembership[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserMembership {
  id           String              @id @default(cuid())
  userId       String?
  user         User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  membershipId String
  membership   Membership          @relation(fields: [membershipId], references: [id], onDelete: Cascade)
  status       UserMembershipStatus @default(PENDING)
  paymentMethod PaymentMethod      @default(CASH)

  guestName   String?
  guestEmail  String?
  guestPhone  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id             String    @id @default(cuid())
  supabaseAuthId String?   @unique
  email          String?   @unique
  emailVerified  DateTime?
  name           String
  image          String?
  phone          String?
  role           UserRole  @default(USER)
  authType       AuthType  @default(CREDENTIALS)
  passwordHash   String?

  membershipId String?
  membership   Membership? @relation(fields: [membershipId], references: [id], onDelete: SetNull)

  joinedAt    DateTime?
  totalVisits Int      @default(0)
  lastVisit   DateTime?

  massageBookings MassageBooking[]
  scheduleBookings ScheduleBooking[]
  eventBookings EventBooking[]
  userMemberships UserMembership[]

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DaySchedule {
  id  String @id @default(cuid())
  day String @unique

  classes YogaClass[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model YogaClass {
  id          String @id
  name        String
  time        String
  duration    String
  hall        String
  instructor  String
  description String

  dayScheduleId String
  daySchedule   DaySchedule @relation(fields: [dayScheduleId], references: [id], onDelete: Cascade)
  scheduleBookings ScheduleBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model YogaEvent {
  id          String @id
  name        String
  dateLabel   String
  time        String
  duration    String
  hall        String
  price       String
  description String

  eventBookings EventBooking[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Massage {
  id            String @id
  name          String
  iconKey       String
  price30       String
  price60       String
  description   String
  benefits      Json
  availableDays Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MassageBooking {
  id         String   @id @default(cuid())
  massageId  String
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestName  String?
  guestEmail String?
  guestPhone String?
  date       DateTime
  time       String
  duration   Int      // 30 or 60 minutes
  status     String?  // "shown" | "didnt_show" | null
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ScheduleBooking {
  id          String     @id @default(cuid())
  userId      String?
  user        User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  yogaClassId String
  yogaClass   YogaClass  @relation(fields: [yogaClassId], references: [id], onDelete: Cascade)
  guestName   String?
  guestEmail  String?
  guestPhone  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, yogaClassId])
}

model EventBooking {
  id           String     @id @default(cuid())
  userId       String?
  user         User?      @relation(fields: [userId], references: [id], onDelete: Cascade)
  yogaEventId  String
  yogaEvent    YogaEvent  @relation(fields: [yogaEventId], references: [id], onDelete: Cascade)
  guestName    String?
  guestEmail   String?
  guestPhone   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, yogaEventId])
}

model SiteSettings {
  id            Int    @id @default(autoincrement())
  defaultSeason Season @default(summer)

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// Models used by NextAuth PrismaAdapter

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String? @db.Text
  access_token       String? @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String? @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String @unique
  expires    DateTime

  @@unique([identifier, token])
}
