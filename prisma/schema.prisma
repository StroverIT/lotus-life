generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model ScheduleBase {
  id        String   @id @default("default")
  schedule  Json
  updatedAt DateTime @updatedAt
}

model Event {
  id          String        @id @default(cuid())
  title       String
  date        String
  time        String
  location    String
  description String?
  eventSignUps EventSignUp[]
}

model EventSignUp {
  id         String   @id @default(cuid())
  eventId    String
  userId     String?
  guestEmail String?
  guestName  String?
  signedUpAt DateTime @default(now())
  event      Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model ScheduleSignUp {
  id              String   @id @default(cuid())
  scheduleSlotId  String
  userId          String?
  guestEmail      String?
  guestName       String?
  signedUpAt      DateTime @default(now())
}

model User {
  email     String    @id
  name      String
  password  String?   // null for OAuth-only users
  role      String    @default("user")
  provider  String    @default("credentials") // "credentials" | "google" | "facebook" | etc.
  image     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model PricingTier {
  id          String   @id
  name        String
  price       Int
  features    Json
  highlighted Boolean  @default(false)
  sortOrder   Int      @default(0)
  memberships UserMembership[]
}

model UserMembership {
  userId    String      @id
  tierId    String
  validFrom String?
  validTo   String?
  updatedAt DateTime    @updatedAt
  tier      PricingTier @relation(fields: [tierId], references: [id])
}
